# Backend API URL
# Using /api proxy — Vite forwards /api/* → localhost:3000/*
# This works locally AND through ngrok with a single tunnel
VITE_API_URL=/api

# Production: change this to your deployed backend URL
# VITE_API_URL=https://your-backend.railway.app

# Staging bypass OTP — remove this in production
VITE_STAGING_OTP_BYPASS=000000
